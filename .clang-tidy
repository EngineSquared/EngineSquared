---
Checks: "-*, bugprone-string-constructor, bugprone-terminating-continue,
  bugprone-swapped-arguments, bugprone-suspicious-string-compare,
  bugprone-redundant-branch-condition, bugprone-parent-virtual-call,
  bugprone-empty-catch, -bugprone-reserved-identifier"

WarningsAsErrors: "*"
HeaderFileExtensions:
  - ""
  - h
  - hh
  - hpp
  - hxx
  - ipp
ImplementationFileExtensions:
  - c
  - cc
  - cpp
  - cxx
HeaderFilterRegex: "^src/"
FormatStyle: file
User: miouzora
CheckOptions: {}
SystemHeaders: false
...
